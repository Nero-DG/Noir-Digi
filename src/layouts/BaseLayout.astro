---
const { title = 'Poetry', tone = 'main' } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const skins = [
  { id: 'contact', label: 'Contact Sheet' },
  { id: 'xerox', label: 'Heroin Chic Xerox' },
  { id: 'motel', label: 'Flash Motel' },
];
---

<!doctype html>
<html lang="en" data-tone={tone}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      const savedSkin = localStorage.getItem('noir-digi-skin');
      const urlSkin = new URLSearchParams(window.location.search).get('skin');
      const skin = urlSkin || savedSkin || 'contact';
      document.documentElement.dataset.skin = skin;
      localStorage.setItem('noir-digi-skin', skin);
    </script>
    <link rel="icon" type="image/png" href={`${base}favicon.png?v=dg-3`} sizes="64x64" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg?v=dg-3`} />
    <link rel="stylesheet" href={`${base}styles/global.css`} />
  </head>
  <body>
    <a class="site-mark" href={base} aria-label="Noir-digi home">
      <span>N</span><span>D</span>
      <span>O</span><span>I</span>
      <span>I</span><span>G</span>
      <span>R</span><span>I</span>
    </a>
    <nav class="skin-switcher" aria-label="Visual identity">
      {skins.map((skin) => <a href={`?skin=${skin.id}`} data-skin-option={skin.id}>{skin.label}</a>)}
    </nav>
    <slot />
  </body>
</html>
