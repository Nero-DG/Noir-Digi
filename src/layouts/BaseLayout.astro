---
const { title = 'Poetry', tone = 'main' } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="en" data-tone={tone}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href={`${base}favicon.png?v=dg-3`} sizes="64x64" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg?v=dg-3`} />
    <link rel="stylesheet" href={`${base}styles/global.css`} />
  </head>
  <body>
    <a class="site-mark" href={base} aria-label="Noir-digi home">
      <span>N</span><span>D</span>
      <span>O</span><span>I</span>
      <span>I</span><span>G</span>
      <span>R</span><span>I</span>
    </a>
    <slot />
  </body>
</html>
