---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const poems = (await getCollection('poems')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', { 
    year: 'numeric', 
    month: 'short', 
    day: 'numeric' 
  });
};
---

<BaseLayout title="Noir-digi" tone="main">
  <main class="index-page">
    <nav class="poem-index" aria-label="Poems">
      {
        poems.map((poem) => (
          <a href={`${base}poems/${poem.slug}/`}>
            <span class="poem-title">{poem.data.title}</span>
            <span class="poem-date">{formatDate(poem.data.date)}</span>
          </a>
        ))
      }
    </nav>
  </main>
</BaseLayout>
