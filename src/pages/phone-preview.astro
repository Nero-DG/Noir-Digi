---
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Noir-digi phone preview</title>
    <style>
      html,
      body {
        min-height: 100%;
        margin: 0;
        background: #050505;
      }

      body {
        display: grid;
        place-items: start center;
        padding: 24px;
      }

      iframe {
        width: 390px;
        max-width: 100%;
        height: 844px;
        border: 1px solid rgba(255, 255, 255, 0.16);
        background: #000;
      }
    </style>
  </head>
  <body>
    <iframe src={base} title="Noir-digi phone preview"></iframe>
  </body>
</html>
